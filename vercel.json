{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://anikotoapi.site/:path*"
    },
    {
      "source": "/mangadex/:path*",
      "destination": "https://api.mangadex.org/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
